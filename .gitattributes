# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly declare files that should always have LF line endings
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.rst text eol=lf
# Denote all files that are truly binary and should not be modified
